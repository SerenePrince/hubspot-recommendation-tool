{
  "name": "hubspot-recommendation-tool-backend",
  "version": "1.0.0",
  "description": "Minimal Node.js backend for the HubSpot Recommendation Tool, providing analysis APIs, CLI utilities, and optional static frontend serving for integrated deployments.",
  "main": "src/api/server.js",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env src/api/server.js",
    "dev:api": "node --env-file-if-exists=.env src/api/server.js",
    "prestart": "npm run validate-config",
    "start": "node src/api/server.js",
    "cli": "node --env-file-if-exists=.env src/cli/index.js",
    "cli:help": "node --env-file-if-exists=.env src/cli/index.js --help",
    "cli:human": "node --env-file-if-exists=.env src/cli/index.js --format human",
    "cli:pretty": "node --env-file-if-exists=.env src/cli/index.js --format json-pretty",
    "cli:tax": "node --env-file-if-exists=.env src/cli/taxonomy.js",
    "cli:check": "node src/scripts/cliCheck.js",
    "smoke": "node --env-file-if-exists=.env src/scripts/smokeTest.js",
    "validate-config": "node --env-file-if-exists=.env src/scripts/validateConfig.js",
    "update:techdb": "bash src/scripts/update-webappanalyzer-db.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "node",
    "backend",
    "api",
    "hubspot",
    "analysis",
    "vite",
    "static-serving"
  ],
  "author": "Team Debug",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "cheerio": "^1.2.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
