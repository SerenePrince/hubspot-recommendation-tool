# Copy this file to backend/.env for local development.
# Copy this file to backend/.env.production for production defaults (then inject secrets).
NODE_ENV=development
PORT=3001

DATA_ROOT=./data/vendor/webappanalyzer/src
FETCH_TIMEOUT_MS=12000
MAX_FETCH_BYTES=2000000

REQUEST_LOG=1
CORS_ALLOW_ORIGIN=*

SERVE_STATIC=0
STATIC_DIST_DIR=../frontend/dist
STATIC_ASSET_CACHE_SECONDS=0

# Analysis guardrails
MAX_CONCURRENT_ANALYSES=8
MAX_QUEUED_ANALYSES=32

# HTTP server hardening
HTTP_REQUEST_TIMEOUT_MS=30000
HTTP_HEADERS_TIMEOUT_MS=35000
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
HTTP_MAX_REQUESTS_PER_SOCKET=100

# Auth (HTTP Basic) — recommended ON in production (over HTTPS)
AUTH_ENABLED=0
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_REALM=Internal Tool
AUTH_ALLOW_HEALTH=1

AUTH_RATE_LIMIT_ENABLED=1
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_FAILURES=12
AUTH_RATE_LIMIT_BLOCK_MS=300000