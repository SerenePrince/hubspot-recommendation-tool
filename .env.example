# Root `.env` example (used by `docker compose`).
# Copy to `.env` in the project root and set values.
#
# Notes:
# - Do NOT commit `.env` (secrets).
# - Backend config is environment-driven; see `backend/docs/ENVIRONMENT.md` for the authoritative reference.

# -----------------------------
# Security / authentication
# -----------------------------
# Recommended: keep enabled for any shared/staged deployment (must run behind HTTPS).
AUTH_ENABLED=1
AUTH_USERNAME=change-me
AUTH_PASSWORD=change-me
AUTH_REALM=Internal Tool

# Leave health open for Docker/hosting probes unless your platform supports auth on probes.
AUTH_ALLOW_HEALTH=1

# Failed-auth throttling (best-effort, in-memory; resets on restart)
AUTH_RATE_LIMIT_ENABLED=1
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_FAILURES=12
AUTH_RATE_LIMIT_BLOCK_MS=300000

# -----------------------------
# Core runtime
# -----------------------------
NODE_ENV=production
PORT=3001
REQUEST_LOG=1

# -----------------------------
# Frontend integration (single-container)
# -----------------------------
SERVE_STATIC=1
STATIC_DIST_DIR=/app/frontend/dist
STATIC_ASSET_CACHE_SECONDS=2592000

# Same-origin frontend+backend in Docker; keep CORS disabled.
CORS_ALLOW_ORIGIN=off

# -----------------------------
# Detection dataset (inside container image)
# -----------------------------
DATA_ROOT=/app/backend/data/vendor/webappanalyzer/src

# -----------------------------
# Performance / safety limits
# -----------------------------
FETCH_TIMEOUT_MS=12000
MAX_FETCH_BYTES=2000000
MAX_CONCURRENT_ANALYSES=8
MAX_QUEUED_ANALYSES=32

# HTTP server hardening
HTTP_REQUEST_TIMEOUT_MS=30000
HTTP_HEADERS_TIMEOUT_MS=35000
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
HTTP_MAX_REQUESTS_PER_SOCKET=100

# -----------------------------
# Debug (internal)
# -----------------------------
DEBUG_SIGNALS=0