# Root .env template — used by docker compose.
# Copy to .env in the project root and fill in your values.
#
# - Do NOT commit .env (it contains credentials).
# - See backend/docs/ENVIRONMENT.md for the full variable reference and defaults.

# -------------------------------------------------------
# Authentication  (optional — off by default)
# -------------------------------------------------------
# AUTH_ENABLED=0 is the default. Set to 1 to gate the tool behind HTTP Basic Auth.
# If enabled, set AUTH_USERNAME and AUTH_PASSWORD to non-empty values.
# Auth is only effective over HTTPS — do not expose over plain HTTP.
AUTH_ENABLED=0
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_REALM=Internal Tool

# Keep /health public so container orchestrators can probe it without credentials.
AUTH_ALLOW_HEALTH=1

# Failed-auth rate limiting (in-memory, best-effort; resets on process restart).
AUTH_RATE_LIMIT_ENABLED=1
AUTH_RATE_LIMIT_WINDOW_MS=60000      # 1 minute — sliding failure counting window
AUTH_RATE_LIMIT_MAX_FAILURES=12      # failures allowed per window before IP is blocked
AUTH_RATE_LIMIT_BLOCK_MS=300000      # 5 minutes — block duration after threshold is hit

# -------------------------------------------------------
# Core runtime
# -------------------------------------------------------
NODE_ENV=production
PORT=3001
REQUEST_LOG=1                        # structured JSON request logs; recommended in production

# -------------------------------------------------------
# Frontend integration (single-container Docker mode)
# -------------------------------------------------------
SERVE_STATIC=1
STATIC_DIST_DIR=/app/frontend/dist
STATIC_ASSET_CACHE_SECONDS=2592000   # 30 days; applies only to hashed Vite asset files

# Same-origin frontend and backend in Docker; CORS headers are not needed.
CORS_ALLOW_ORIGIN=off

# -------------------------------------------------------
# Detection dataset (bundled inside the container image)
# -------------------------------------------------------
DATA_ROOT=/app/backend/data/vendor/webappanalyzer/src

# -------------------------------------------------------
# Performance and safety limits
# -------------------------------------------------------
FETCH_TIMEOUT_MS=12000               # 12 seconds — wall-clock deadline for fetching a target page
MAX_FETCH_BYTES=2000000              # 2 MB — primary response body cap
MAX_CONCURRENT_ANALYSES=8           # max simultaneous analysis requests
MAX_QUEUED_ANALYSES=32              # max requests waiting for a free slot before 503

# HTTP server socket hardening
HTTP_REQUEST_TIMEOUT_MS=30000        # 30 seconds
HTTP_HEADERS_TIMEOUT_MS=35000        # must be >= HTTP_REQUEST_TIMEOUT_MS
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
HTTP_MAX_REQUESTS_PER_SOCKET=100

# -------------------------------------------------------
# Debug (development only)
# -------------------------------------------------------
# Set to 1 to include raw signal debug info in /analyze responses.
# Never enable in production — exposes internal detection details.
DEBUG_SIGNALS=0
